# OpenCTI Environment Variables
# Copy this file to .env and fill in your values

# Admin password for local admin login (default: admin123)
ADMIN_PASSWORD=admin123

# AlienVault OTX API Key (get yours at https://otx.alienvault.com)
OTX_API_KEY=

# PostgreSQL connection (used in Docker deployment)
DATABASE_URL=postgresql://opencti:opencti_secret@opencti-db:5432/opencti

# Node environment
NODE_ENV=production

# SMTP Email Server (for sending advisory reports)
# Gmail: Use smtp.gmail.com with port 587 and an App Password
# Outlook: Use smtp.office365.com with port 587
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_FROM_NAME=OpenCTI Threat Advisory
